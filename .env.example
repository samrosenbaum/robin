# Vercel AI Gateway — required. Routes Anthropic calls via Vercel.
# https://vercel.com/dashboard → AI Gateway → Create API Key
AI_GATEWAY_API_KEY=

# v0 Platform API — required for the v0 build step.
# https://v0.dev/chat/settings/keys
V0_API_KEY=

# Vercel Sandbox — required for the isolated build step.
# Run `vercel link` in this directory, then `vercel env pull` to populate.
# Or set these manually:
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
