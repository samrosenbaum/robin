# Vercel AI Gateway — required. All model calls route through Eve's
# AI Gateway integration. Without this key, Eve will fail to call the model.
# https://vercel.com/dashboard → AI Gateway → Create API Key
AI_GATEWAY_API_KEY=

# v0 Platform API — required for the build_landing_page tool.
# https://v0.dev/chat/settings/keys
V0_API_KEY=

# Slack — optional. Without these, post_to_slack returns a draft preview only.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Linear — optional. Without both, open_linear_ticket returns a draft preview.
LINEAR_API_KEY=
LINEAR_TEAM_ID=
